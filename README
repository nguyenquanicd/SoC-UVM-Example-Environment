//TB Directory
├── filelist_dv.f (DV filelist)
├── filelist_rtl.f (RTL filelist)
├── run.csh (run script)
├── seq
│   ├── FILES_test_seq.sv
│   ├── soc_base_vseq.sv
│   └── soc_seq_pkg.sv
├── SourceMe.csh (set env variables)
├── synopsys_sim.setup (set up different lib for RTL & DV)
├── tb
│   ├── tb_macro.sv (macros for testbench)
│   └── tb_top.sv (testbench top)
├── test
│   ├── soc_base_test.sv
│   └── soc_test_pkg.sv
└── vip (open source VIP)
    ├── ahb_vip
    ├── apb_vip
    ├── axi_vip
    ├── i2s_vip
    ├── i3c_vip
    ├── jtag_vip
    ├── spi_vip
    └── uart_vip

